# Supabase credentials (get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # legacy alias, falls back if publishable key unset
SUPABASE_SECRET_API_KEY=your-supabase-secret-api-key

# Quran Foundation environment selection
# Allowed values: prelive | production
QF_ENV=prelive

# Quran Foundation OAuth2 client credentials (server-side only)
QF_CLIENT_ID=your-qf-client-id
QF_CLIENT_SECRET=your-qf-client-secret

# Quran Foundation User API credentials (server-side only)
# Used for OAuth login and user-scoped features (bookmarks, etc.)
QF_USER_OAUTH_REDIRECT_URI=http://localhost:3000/api/user/oauth/callback
QF_USER_OAUTH_SCOPE=openid offline_access user bookmark
QF_USER_SCOPE=user
QF_USER_API_BASE_PATH=/user/api/v1
QF_USER_BOOKMARKS_PATH=/bookmarks
QF_USER_PROFILE_PATH=/profile

# Quran proxy cache policy (server-side only)
QF_CACHE_MAX_AGE=3600
QF_CACHE_S_MAXAGE_CHAPTERS=86400
QF_CACHE_SWR_CHAPTERS=604800
QF_CACHE_S_MAXAGE_VERSES=2592000
QF_CACHE_SWR_VERSES=31536000

# Client-side Quran defaults
NEXT_PUBLIC_DEFAULT_RECITATION_ID=7
NEXT_PUBLIC_AUDIO_CDN_BASE=https://audio.qurancdn.com

# Auto reveal timing defaults
NEXT_PUBLIC_REVEAL_MIN_SECONDS=6
NEXT_PUBLIC_REVEAL_MAX_SECONDS=20
NEXT_PUBLIC_REVEAL_CHARS_PER_SECOND=12

# ── Advanced / optional overrides ─────────────────────────────────────────────

# Explicit base URL overrides for the active QF_ENV (server-side only)
# Set these when proxying through a custom gateway or testing against a local mock.
# QF_API_BASE_URL=https://apis-prelive.quran.foundation
# QF_AUTH_BASE_URL=https://prelive-oauth2.quran.foundation
# QF_USER_API_BASE_URL=
# QF_USER_AUTH_BASE_URL=

# Scope overrides
# QF_CONTENT_SCOPE=content

# Session and token tuning
# QF_SESSION_COOKIE_MAX_AGE=2592000   # seconds  (default: 30 days)
# QF_OAUTH_STATE_TTL=600              # seconds  (default: 10 min)
# QF_TOKEN_EXPIRY_BUFFER_MS=30000     # ms       (default: 30s)
# QF_TOKEN_EXPIRY_SOON_MS=300000      # ms       (default: 5 min)

# Bookmark rate limiting
# BOOKMARK_RATE_LIMIT_WINDOW_MS=60000 # ms       (default: 60s)
# BOOKMARK_RATE_LIMIT_MAX=30          # requests (default: 30)
